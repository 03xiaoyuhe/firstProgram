<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <!--
    有关 web.config 更改的说明，请参见 http://go.microsoft.com/fwlink/?LinkId=235367。

    可在 <httpRuntime> 标记上设置以下特性。
      <system.Web>
        <httpRuntime targetFramework="4.8.1" />
      </system.Web>
  -->
  <system.web>
	  <globalization fileEncoding ="utf-8"/>
    <compilation debug="true" targetFramework="4.8.1">
      <assemblies>
        <add assembly="System.Web.Entity, Version=4.0.0.0, Culture=neutral, PublicKeyToken=B77A5C561934E089"/>
        <add assembly="System.Data.Entity, Version=4.0.0.0, Culture=neutral, PublicKeyToken=B77A5C561934E089"/>
      </assemblies>
    </compilation>
    <pages controlRenderingCompatibilityVersion="4.0"/>
  </system.web>
  <!--windows登录-->
  <connectionStrings>
    <add name="connection" connectionString="data source=(local); database=社会哲学项目; Integrated Security=SSPI" providerName="System.Data.SqlClient"/>
    <!--sa登录-->
    <add name="conn" connectionString="server=LAPTOP-SESUCEUV;database=form;uid=sa;pwd=***;" providerName="System.Data.SqlClient"/>
    <!--账号密码登陆-->
    <add name="SQpwdLoad" connectionString="Data Source=.;Initial Catalog=Social Philosophy Project;User Id=sa;Password=0.0.00.0;" providerName="System.Data.SqlClient"/>
  </connectionStrings>
</configuration>